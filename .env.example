# Copy to .env and fill in your own values. Never commit the real .env file.

# VPS Tailscale IP or hostname running Mosquitto
MQTT_HOST=100.x.x.x
# MQTT port (plaintext is fine here since Tailscale encrypts the tunnel)
MQTT_PORT=1883
# Mosquitto credentials (leave both blank for an anonymous broker)
MQTT_USER=your-user
MQTT_PASSWORD=your-password
# Use a distinct topic per NAS instance, e.g. truenas/nas1/snmp_trap
MQTT_TOPIC=truenas/nas1/snmp_trap
# Optional: SNMP community string used by snmptrapd (default: public)
SNMP_COMMUNITY=public
# Optional: max seconds to let a single MQTT publish attempt run before
# giving up (default: 10). Keeps a broken broker connection (e.g. a
# Tailscale ACL issue) failing fast and loudly instead of hanging silently.
MQTT_TIMEOUT=10
# Optional: retained-state topic prefix for per-alert entities, one alert
# per {prefix}/{alertId} (default: truenas/alerts)
ALERT_STATE_TOPIC_PREFIX=truenas/alerts
# Optional: Home Assistant MQTT discovery prefix (default: homeassistant)
HA_DISCOVERY_PREFIX=homeassistant
# Optional: prefixed onto each alert's message (e.g. "nas1: pool tank
# DEGRADED"), so notifications identify which NAS fired when running
# multiple instances (default: TrueNAS)
NAS_NAME=nas1
